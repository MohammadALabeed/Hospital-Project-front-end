{
  "compilerOptions": {
    // تحديد إصدار كود الـ JavaScript النهائي الذي سيتم تحويل ملفاتك إليه (هنا إصدار سنة 2022 الحديث)
    "target": "ES2022",

    // تفعيل ميزة "المزخرفات" (Decorators) وهي ميزة برمجية متقدمة تستخدمها بعض المكتبات لتعديل سلوك الدوال والكلاسات
    "experimentalDecorators": true,

    // التحكم في الطريقة القديمة أو الحديثة لمعالجة المتغيرات (Fields) داخل الكلاسات
    "useDefineForClassFields": false,

    // تحديد نظام الوحدات (Modules) المستخدم لربط الملفات ببعضها (استخدام أحدث نظام وهو ESNext)
    "module": "ESNext",

    // إعلام المترجم بالبيئات التي سيعمل فيها الكود (هنا المتصفح DOM، وخصائص لغة JavaScript الحديثة)
    "lib": ["ES2022", "DOM", "DOM.Iterable"],

    // تسريع وقت فحص الكود عن طريق تخطي فحص ملفات التعريف الخاصة بالمكتبات الخارجية (مثل المكتبات في node_modules)
    "skipLibCheck": true,

    // تحديد طريقة البحث عن الملفات والمكتبات المستوردة لتتوافق مع أدوات الحزم الحديثة مثل Vite
    "moduleResolution": "bundler",

    // إجبار المترجم على التعامل مع كل ملف بشكل مستقل تماماً، وهو أمر ضروري جداً لتوافق المشروع مع أداة Vite
    "isolatedModules": true,

    // إجبار المترجم على اعتبار كل ملف في المشروع عبارة عن Module مستقل تلقائياً دون الحاجة لكتابة import في أوله
    "moduleDetection": "force",

    // السماح للمشروع بقراءة وتشغيل ملفات JavaScript العادية (`.js`) جنباً إلى جنب مع ملفات TypeScript
    "allowJs": true,

    // إعداد واجهة ريأكت (JSX) ليتم دعمها وتحويلها تلقائياً باستخدام المحرك الحديث (react-jsx) دون الحاجة لاستيراد React في كل صفحة
    "jsx": "react-jsx",

    // ربط الاختصارات (نفس الـ Alias اللي عملناه في ملف vite): يتيح لك استخدام الرمز '@' للوصول للمجلد الرئيسي لتجنب المسارات الطويلة
    "paths": {
      "@/*": ["./*"]
    },

    // السماح لك باستيراد الملفات البرمجية حتى لو كتبت امتدادها الصريح مثل (`.ts` أو `.tsx`) داخل كودك
    "allowImportingTsExtensions": true,

    // إخبار المترجم بعدم توليد ملفات JavaScript نهائية من هذا الملف، لأن أداة Vite هي من سيتولى عملية توليد الكود النهائي للمتصفح
    "noEmit": true
  }
}
